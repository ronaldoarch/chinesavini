VITE_API_URL=http://localhost:5000/api

# URL pública do site (sem barra no final). Usada no build para og:image e og:url (WhatsApp / redes).
# A miniatura do link usa GET /api/banners/logo-opengraph na API (configure FRONTEND_URL no backend para logo em /logo_plataforma.png).
# VITE_PUBLIC_SITE_URL=https://seudominio.com

# Opcional: sobrescrever meta sem buscar a API (build estático)
# VITE_HTML_TITLE=Minha Plataforma
# VITE_OG_DESCRIPTION=Texto do preview do link
# VITE_OG_IMAGE=https://seudominio.com/assets/og-banner.png

# Opcional: versão fixa na URL og:image para invalidar cache WhatsApp (ex.: após trocar a imagem sem redeploy)
# VITE_OG_IMAGE_VERSION=2
