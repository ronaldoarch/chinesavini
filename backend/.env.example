# Server Configuration
PORT=5000
NODE_ENV=development

# Database (MongoDB or PostgreSQL)
# For MongoDB:
MONGODB_URI=mongodb://localhost:27017/fortune-bet
# For PostgreSQL (Colify/Railway):
# DATABASE_URL=postgresql://user:password@host:port/database

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# CORS
FRONTEND_URL=http://localhost:3000

# Uploads (logos, banners) - OBRIGATÓRIO no Colify com Persistent Storage
# Colify Base Directory /backend → app fica em /app, mas volume monta em /app/backend/uploads
# Sem UPLOADS_PATH o backend salva em /app/uploads (efêmero, perde no deploy)
# Adicione nas Environment Variables do Backend no Colify:
# UPLOADS_PATH=/app/backend/uploads

# NXGATE API
NXGATE_API_KEY=d6fd1a0ed8daf4b33754d9f7d494d697
WEBHOOK_BASE_URL=http://localhost:5000

# Saque PIX: taxa fixa que o PSP desconta do valor da ordem (ex.: enviar R$20 ao PIX e cobrar R$1,50 sobre a transferência → destinatário recebia R$18,50).
# Somamos esta taxa ao valor enviado à API do gateway para o usuário receber exatamente o valor solicitado; só o valor solicitado é debitado do saldo do jogador.
# GATEWAY_PIX_OUT_FEE_BRL=1.5
# WITHDRAW_ABSORB_GATEWAY_PIX_FEE=true

# SarrixPay (opcional — preferência: Gateway no admin MongoDB)
# SARRIXPAY_CLIENT_ID=be9cd100-e83f-4d3f-bc5b-695ec1aa2e04
# SARRIXPAY_CLIENT_SECRET=cs_live_xxxxxxxx

# IGAMEWIN API (API Link Guide: agent 4916vini)
IGAMEWIN_AGENT_CODE=4916vini
IGAMEWIN_AGENT_TOKEN=2b887a93fcbd11f098a0bc2411881493
# agent_secret do painel iGameWin (obrigatório para Seamless Site API)
IGAMEWIN_AGENT_SECRET=
# true = saldo em reais (jogo exibe 12); false = centavos (doc: 1200)
IGAMEWIN_BALANCE_IN_REAIS=true
# true = bet_money/win_money em reais (0.4 = R$0,40); false = centavos (40 = R$0,40). Obrigatório debitar/creditar corretamente
IGAMEWIN_BET_WIN_IN_REAIS=true

# Facebook / Meta Conversions API (eventos: Lead, Purchase, etc.)
# FACEBOOK_PIXEL_ID=123456789
# FACEBOOK_ACCESS_TOKEN=your-token
# FACEBOOK_API_VERSION=v18.0
